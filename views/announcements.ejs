<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Announcements</h1>
                <p class="text-gray-500 text-sm mt-1">Broadcast messages to students</p>
            </div>
            <a href="/admin/announcements/new" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Announcement
            </a>
        </div>

        <% if (announcements.length === 0) { %>
        <div class="bg-white rounded-2xl border border-gray-100 p-16 text-center">
            <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0 1 18 14.158V11a6.002 6.002 0 0 0-4-5.659V5a2 2 0 1 0-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 1 1-6 0v-1m6 0H9"/></svg>
            </div>
            <h3 class="font-semibold text-gray-700 mb-1">No announcements yet</h3>
            <p class="text-gray-400 text-sm">Create your first announcement to broadcast to students.</p>
            <a href="/admin/announcements/new" class="mt-4 inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 text-sm font-medium">Create One →</a>
        </div>
        <% } else { %>
        <div class="grid grid-cols-1 gap-4">
            <% announcements.forEach(function(a) { %>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-start justify-between gap-4 hover:shadow-md transition-shadow">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1.5">
                        <h3 class="font-semibold text-gray-900"><%= a.title %></h3>
                        <% if (a.target_course) { %>
                        <span class="text-xs bg-blue-100 text-blue-700 font-medium px-2 py-0.5 rounded-full"><%= a.target_course %></span>
                        <% } else { %>
                        <span class="text-xs bg-green-100 text-green-700 font-medium px-2 py-0.5 rounded-full">All Students</span>
                        <% } %>
                    </div>
                    <p class="text-sm text-gray-500 truncate"><%= a.body %></p>
                    <p class="text-xs text-gray-400 mt-2">Created <%= new Date(a.created_at).toLocaleDateString('en-IN') %>
                        <% if (a.publish_at) { %> · Publishes <%= new Date(a.publish_at).toLocaleDateString('en-IN') %><% } %>
                    </p>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    <a href="/admin/announcements/<%= a.id %>/edit" class="text-sm text-gray-600 hover:text-gray-800 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition-colors">Edit</a>
                    <form action="/admin/announcements/<%= a.id %>/delete" method="POST" onsubmit="return confirm('Delete this announcement?')">
                        <button type="submit" class="text-sm text-red-500 hover:text-red-700 px-3 py-1.5 rounded-lg hover:bg-red-50 transition-colors">Delete</button>
                    </form>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </main>
</div>
</body>
</html>
