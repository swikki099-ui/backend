<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                    <a href="/admin/users" class="hover:text-blue-600">Users</a>
                    <span>/</span>
                    <span class="text-gray-900 font-medium"><%= user.name || 'Student Profile' %></span>
                </div>
                <h1 class="text-2xl font-bold text-gray-900"><%= user.name || 'Unknown Student' %></h1>
            </div>
            <div class="flex gap-2">
                <a href="/admin/users/<%= user.id %>/edit" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-5">
            <!-- Profile Card -->
            <div class="xl:col-span-1">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-400 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
                        <%= user.name ? user.name.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900"><%= user.name %></h2>
                    <p class="text-gray-500 text-sm mt-1"><%= user.email %></p>
                    <div class="mt-3">
                        <% if (user.profile_complete) { %>
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-100 px-3 py-1.5 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Profile Complete
                        </span>
                        <% } else { %>
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-100 px-3 py-1.5 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
                            Incomplete Profile
                        </span>
                        <% } %>
                    </div>
                    <!-- Ban section -->
                    <% if (activeBan) { %>
                    <div class="mt-5 bg-red-50 border border-red-200 rounded-xl p-4 text-left">
                        <p class="text-red-700 text-xs font-semibold uppercase tracking-wide mb-1">⚠ Currently Banned</p>
                        <p class="text-red-600 text-sm"><%= activeBan.reason %></p>
                        <% if (activeBan.expires_at) { %>
                        <p class="text-red-400 text-xs mt-1">Expires: <%= new Date(activeBan.expires_at).toLocaleDateString('en-IN') %></p>
                        <% } else { %>
                        <p class="text-red-400 text-xs mt-1">Permanent ban</p>
                        <% } %>
                        <form action="/admin/users/<%= user.id %>/action" method="POST" class="mt-3">
                            <input type="hidden" name="_action" value="unban">
                            <button type="submit" class="w-full text-xs font-semibold text-red-600 border border-red-300 hover:bg-red-100 py-2 rounded-lg transition-colors">Lift Ban</button>
                        </form>
                    </div>
                    <% } else { %>
                    <button onclick="document.getElementById('banSection').classList.toggle('hidden')" class="mt-4 w-full text-sm font-medium text-amber-600 border border-amber-200 hover:bg-amber-50 py-2 rounded-xl transition-colors">
                        Ban This User
                    </button>
                    <div id="banSection" class="hidden mt-3 text-left">
                        <form action="/admin/users/<%= user.id %>/action" method="POST">
                            <input type="hidden" name="_action" value="ban">
                            <textarea name="reason" rows="2" required placeholder="Ban reason..." class="w-full text-sm border border-gray-200 rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500/30 mb-2 resize-none"></textarea>
                            <input type="date" name="expires_at" class="w-full text-sm border border-gray-200 rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500/30 mb-3">
                            <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white text-sm font-semibold py-2 rounded-xl transition-colors">Confirm Ban</button>
                        </form>
                    </div>
                    <% } %>

                    <form action="/admin/users/<%= user.id %>/action" method="POST" onsubmit="return confirm('Permanently delete this user? This cannot be undone.')">
                        <input type="hidden" name="_action" value="delete">
                        <button type="submit" class="mt-2 w-full text-sm font-medium text-red-600 border border-red-200 hover:bg-red-50 py-2 rounded-xl transition-colors">
                            Delete User
                        </button>
                    </form>
                </div>
            </div>

            <!-- Details -->
            <div class="xl:col-span-2 space-y-5">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <h3 class="font-semibold text-gray-900 mb-5 text-base">Student Information</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <% const fields = [
                            {label: 'College ID', value: user.college_id},
                            {label: 'Roll Number', value: user.roll_no},
                            {label: 'Course', value: user.course},
                            {label: 'Branch', value: user.branch},
                            {label: 'Semester', value: user.semester},
                            {label: 'Section', value: user.section},
                            {label: 'Phone', value: user.phone},
                            {label: 'Barcode ID', value: user.barcode_id},
                        ]; %>
                        <% fields.forEach(function(f) { %>
                        <div>
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1"><%= f.label %></p>
                            <p class="text-gray-900 font-medium"><%= f.value || '—' %></p>
                        </div>
                        <% }); %>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <h3 class="font-semibold text-gray-900 mb-4 text-base">Activity Timeline</h3>
                    <div class="space-y-3">
                        <div class="flex items-start gap-3">
                            <div class="w-7 h-7 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-900">Account Created</p>
                                <p class="text-xs text-gray-400"><%= user.created_at ? new Date(user.created_at).toLocaleString('en-IN') : '—' %></p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/></svg>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-900">Last Updated</p>
                                <p class="text-xs text-gray-400"><%= user.updated_at ? new Date(user.updated_at).toLocaleString('en-IN') : '—' %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
</body>
</html>
