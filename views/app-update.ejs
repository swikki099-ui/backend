<%- include('partials/head') %>

<div class="flex">
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        
        <!-- Page Header -->
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">App Updates</h1>
                <p class="text-gray-500 text-sm mt-1">Manage APK versions, force updates, and release notes.</p>
            </div>
            <div class="bg-blue-600 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-blue-200">
                Current: v<%= currentVersion.version %>
            </div>
        </div>

        <% if (flash) { %>
        <div class="mb-5 flex items-center gap-2 bg-green-100 border border-green-300 text-green-700 text-sm px-4 py-3 rounded-xl">
            <%= flash.message %>
        </div>
        <% } %>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
            <!-- Publish New Update Form -->
            <div class="xl:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
                    <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-6">Publish New Version</h2>
                    
                    <form action="/admin/app-update" method="POST" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Version Name</label>
                                <input type="text" name="version" required placeholder="e.g., 2.1.0" 
                                       class="w-full text-sm border border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500/10 focus:border-blue-400">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Download URL</label>
                                <input type="url" name="download_url" required placeholder="https://..." 
                                       class="w-full text-sm border border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500/10 focus:border-blue-400">
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Update Message</label>
                            <input type="text" name="message" required placeholder="A new update is available!" 
                                   class="w-full text-sm border border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500/10 focus:border-blue-400">
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Release Notes</label>
                            <textarea name="release_notes" rows="4" placeholder="Fixed login bugs, added dark mode..." 
                                      class="w-full text-sm border border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500/10 focus:border-blue-400"></textarea>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-blue-50/50 rounded-2xl border border-blue-100/50">
                            <div>
                                <h3 class="text-sm font-semibold text-blue-900">Force Update</h3>
                                <p class="text-[11px] text-blue-600">Users will be blocked from using the app until they update.</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" name="force" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>

                        <div class="flex justify-end">
                            <button type="submit" class="px-8 py-3 bg-blue-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all active:scale-95">
                                Publish Version
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Version History Sidebar -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-50 bg-gray-50/50">
                        <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Update History</h2>
                    </div>
                    <div class="divide-y divide-gray-50">
                        <% history.forEach(v => { %>
                        <div class="p-5 hover:bg-gray-50/50 transition-colors">
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-sm font-bold text-gray-900">v<%= v.version %></span>
                                <% if (v.is_current) { %>
                                <span class="text-[10px] font-bold text-white bg-green-500 px-2 py-0.5 rounded-full uppercase">Current</span>
                                <% } %>
                            </div>
                            <p class="text-[11px] text-gray-500 line-clamp-1"><%= v.message %></p>
                            <div class="flex items-center gap-2 mt-2">
                                <span class="text-[10px] text-gray-400"><%= new Date(v.created_at).toLocaleDateString() %></span>
                                <% if (v.force) { %>
                                <span class="text-[10px] font-bold text-orange-500">• Forced</span>
                                <% } %>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-indigo-600 rounded-2xl p-6 text-white shadow-xl shadow-indigo-100 italic">
                    <p class="text-sm leading-relaxed">
                        "These settings are retrieved directly from the database and override all local configurations."
                    </p>
                </div>
            </div>
        </div>
    </main>
</div>

</body>
</html>
