<%- include('partials/head') %>

<div class="flex">
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <% if (locals.flash) { %>
                <div class="mb-6 p-4 rounded-md bg-green-50 border border-green-200 flex items-center">
                    <i data-feather="check-circle" class="text-green-500 mr-3"></i>
                    <span class="text-green-800 text-sm font-medium"><%= flash.message %></span>
                </div>
            <% } %>

        <div class="mb-8 flex justify-between items-end">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Social Moderation Hub</h1>
                <p class="mt-1 text-sm text-gray-500">The Oracle view. Monitor campus feeds and resolve reported posts.</p>
            </div>
            <div>
                <a href="/admin/app-settings" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700">
                    <i data-feather="power" class="w-4 h-4 mr-2"></i> Global Kill Switch
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Left Column: Pending Reports -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-lg shadow border border-red-100 overflow-hidden">
                    <div class="px-4 py-3 bg-red-50 border-b border-red-100 flex items-center justify-between">
                        <h3 class="text-sm font-bold text-red-800 flex items-center">
                            <i data-feather="alert-triangle" class="w-4 h-4 mr-2"></i> Action Required
                        </h3>
                        <span class="px-2 py-1 bg-red-100 text-red-800 text-xs font-semibold rounded-full"><%= reports.length %> Pending</span>
                    </div>
                    <ul class="divide-y divide-gray-200 max-h-[600px] overflow-y-auto">
                        <% if (reports.length === 0) { %>
                            <li class="px-4 py-8 text-center text-sm text-gray-500">No active reports.</li>
                        <% } %>
                        <% reports.forEach(report => { %>
                            <li class="px-4 py-4 hover:bg-gray-50">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-xs font-semibold text-gray-900">Reported by <%= report.reporter_name %></span>
                                    <span class="text-[10px] text-gray-500"><%= new Date(report.created_at).toLocaleDateString() %></span>
                                </div>
                                <p class="text-xs font-semibold text-red-600 mb-2">Reason: "<%= report.reason %>"</p>
                                <div class="bg-gray-100 rounded p-2 text-xs text-gray-700 mb-3 border-l-2 border-gray-300 line-clamp-2">
                                    <%= report.content || "[Media Post]" %>
                                </div>
                                <div class="flex gap-2">
                                    <form action="/admin/social/post/<%= report.post_id %>/delete" method="POST" class="flex-1" onsubmit="return confirm('Nuke this post permanently?');">
                                        <button type="submit" class="w-full inline-flex justify-center items-center px-2 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-red-600 hover:bg-red-700 shadow-sm">
                                            Nuke Post
                                        </button>
                                    </form>
                                    <form action="/admin/social/report/<%= report.id %>/dismiss" method="POST" class="flex-1">
                                        <button type="submit" class="w-full inline-flex justify-center items-center px-2 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 shadow-sm">
                                            Dismiss
                                        </button>
                                    </form>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>

            <!-- Right Column: Live Feed -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-lg shadow border border-gray-200">
                    <div class="px-6 py-4 border-b border-gray-200">
                        <h3 class="text-lg font-medium text-gray-900">Live Campus Feed</h3>
                    </div>
                    <ul class="divide-y divide-gray-200 max-h-[800px] overflow-y-auto">
                        <% if (posts.length === 0) { %>
                            <li class="px-6 py-12 text-center text-gray-500">The social feed is currently empty.</li>
                        <% } %>
                        <% posts.forEach(post => { %>
                            <li class="p-6 hover:bg-gray-50 flex gap-4 transition duration-150">
                                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 text-blue-600 font-bold overflow-hidden">
                                    <!-- Assume image exists or fallback -->
                                    <i data-feather="user" class="w-5 h-5"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900"><%= post.author_name %></p>
                                            <p class="text-xs text-gray-500"><%= new Date(post.created_at).toLocaleString() %></p>
                                        </div>
                                        <form action="/admin/social/post/<%= post.id %>/delete" method="POST" onsubmit="return confirm('WARNING: Permanently delete this post and its media?');">
                                            <button type="submit" class="text-gray-400 hover:text-red-600 transition">
                                                <i data-feather="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        </form>
                                    </div>
                                    
                                    <p class="text-sm text-gray-800 mt-2 whitespace-pre-wrap"><%= post.content %></p>

                                    <% if (post.media_url) { %>
                                        <div class="mt-3">
                                            <% if (post.media_type === 'image') { %>
                                                <img src="<%= post.media_url.split('|')[0] %>" class="rounded-lg max-h-64 object-cover border border-gray-200">
                                            <% } else { %>
                                                <a href="<%= post.media_url.split('|')[0] %>" target="_blank" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-xs leading-4 font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                                                    <i data-feather="file" class="w-4 h-4 mr-2"></i> View Attached Document
                                                </a>
                                            <% } %>
                                        </div>
                                    <% } %>
                                    
                                    <% if (post.report_count > 0) { %>
                                        <div class="mt-3 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                            <i data-feather="flag" class="w-3 h-3 mr-1"></i> Flagged for review
                                        </div>
                                    <% } %>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>

        </div>
        </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
