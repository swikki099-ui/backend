<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — ITS College</title>
    <meta name="description" content="Secure admin login for ITS College management panel.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    animation: {
                        'gradient': 'gradient 6s ease infinite',
                        'fade-in': 'fadeIn 0.6s ease-out',
                    },
                    keyframes: {
                        gradient: {
                            '0%, 100%': { backgroundPosition: '0% 50%' },
                            '50%': { backgroundPosition: '100% 50%' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0', transform: 'translateY(16px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .bg-animated {
            background: linear-gradient(-45deg, #0f172a, #1e1b4b, #0f172a, #1e3a5f);
            background-size: 400% 400%;
            animation: gradient 8s ease infinite;
        }

        @keyframes gradient {

            0%,
            100% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }
        }

        .glass {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Discord specific styling */
        .btn-discord {
            background-color: #5865F2;
            /* Discord Blurple */
            color: white;
            transition: background-color 0.2s, transform 0.1s;
        }

        .btn-discord:hover {
            background-color: #4752C4;
        }

        .btn-discord:active {
            transform: scale(0.98);
        }
    </style>
</head>

<body class="bg-animated min-h-screen flex items-center justify-center p-4">

    <!-- Grid pattern overlay -->
    <div class="fixed inset-0 opacity-5"
        style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%239C92AC\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');">
    </div>

    <!-- Login Card -->
    <div class="glass rounded-2xl p-8 w-full max-w-md shadow-2xl animate-[fadeIn_0.6s_ease-out]">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 bg-blue-600 rounded-2xl mb-4 shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" viewBox="0 0 24 24"
                    fill="currentColor">
                    <path
                        d="M12 3L1 9L12 15L21 10.09V17H23V9L12 3ZM5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z" />
                </svg>
            </div>
            <h1 class="text-white text-2xl font-bold">Admin Panel</h1>
            <p class="text-gray-400 text-sm mt-1">ITS College Management System</p>
        </div>

        <!-- Error -->
        <% if (error) { %>
            <div class="mb-5 flex items-center gap-2 bg-red-500/15 border border-red-500/30 text-red-400 text-sm px-4 py-3 rounded-xl"
                id="error-box">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                <%= error %>
            </div>
            <% } %>

                <!-- Auth Providers -->
                <div class="space-y-3">
                    <p class="text-center text-gray-400 text-xs mb-4 uppercase tracking-widest font-bold">Authorized
                        Logins Only</p>

                    <!-- Discord -->
                    <a href="/admin/auth/discord"
                        class="btn-auth btn-discord w-full font-semibold py-3.5 rounded-xl flex items-center justify-center gap-3 text-sm shadow-lg shadow-[#5865F2]/20 border border-white/5 active:scale-95 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                            viewBox="0 0 127.14 96.36">
                            <path
                                d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.31,60,73.31,53s5-12.74,11.43-12.74S96.3,46,96.19,53,91.08,65.69,84.69,65.69Z" />
                        </svg>
                        <span>Login with Discord</span>
                    </a>

                    <!-- GitHub -->
                    <a href="/admin/auth/github"
                        class="btn-auth bg-gray-800 hover:bg-black text-white w-full font-semibold py-3.5 rounded-xl flex items-center justify-center gap-3 text-sm shadow-lg shadow-black/20 border border-white/5 active:scale-95 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                        <span>Login with GitHub</span>
                    </a>
                </div>

                <p
                    class="text-center text-gray-500 text-[10px] mt-8 leading-relaxed uppercase tracking-widest font-medium">
                    Authorized Personnel Only<br>
                    <span class="text-gray-600">ITS ADMIN ● Neuro Dev </span>
                </p>
    </div>

    <!-- Loading State Script -->
    <script>
        document.querySelectorAll('.btn-auth').forEach(btn => {
            btn.addEventListener('click', function (e) {
                const span = this.querySelector('span');
                const originalText = span.textContent;
                span.textContent = 'Connecting...';
                this.classList.add('cursor-wait', 'opacity-80', 'pointer-events-none');
            });
        });
    </script>
</body>

</html>