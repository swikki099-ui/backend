<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Banned Users</h1>
            <p class="text-gray-500 text-sm mt-1">All active and past bans</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Student</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">College ID</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Reason</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Expires</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Status</th>
                            <th class="text-right px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (bans.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-gray-400 py-16">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                            No banned users
                        </td></tr>
                        <% } %>
                        <% bans.forEach(function(b) { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-semibold text-gray-900"><%= b.user_name || b.college_id %></div>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-gray-600"><%= b.college_id %></td>
                            <td class="px-6 py-4 text-gray-500 max-w-xs truncate"><%= b.reason %></td>
                            <td class="px-6 py-4 text-xs text-gray-500">
                                <%= b.expires_at ? new Date(b.expires_at).toLocaleDateString('en-IN') : 'Permanent' %>
                            </td>
                            <td class="px-6 py-4">
                                <% if (b.is_active) { %>
                                <span class="inline-flex items-center text-xs font-medium text-red-700 bg-red-100 px-2.5 py-1 rounded-full">Active</span>
                                <% } else { %>
                                <span class="inline-flex items-center text-xs font-medium text-gray-500 bg-gray-100 px-2.5 py-1 rounded-full">Expired</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <% if (b.is_active) { %>
                                <form action="/admin/users/<%= b.college_id %>/action" method="POST" class="inline">
                                    <input type="hidden" name="_action" value="unban">
                                    <button type="submit" class="text-xs font-medium text-green-600 hover:text-green-800 px-3 py-1.5 rounded-lg hover:bg-green-50 transition-colors">Lift Ban</button>
                                </form>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
</body>
</html>
